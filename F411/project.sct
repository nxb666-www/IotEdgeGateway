; Scatter file for STM32F411CEUx
; Flash: 0x08000000 - 0x0807FFFF, RAM: 0x20000000 - 0x2001FFFF

LR_IROM1 0x08000000 0x00080000  {
  ER_IROM1 0x08000000 0x00080000  {
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM1 0x20000000 0x00020000  {
   .ANY (+RW +ZI)
  }
}
